# ──────────────────────────────────────────
# Neo4j AuraDB
# ──────────────────────────────────────────
NEO4J_URI=bolt://your_neo4j_uri
NEO4J_USER=neo4j
NEO4J_PASS=your_password

# ──────────────────────────────────────────
# Qdrant Cloud
# ──────────────────────────────────────────
QDRANT_URL=https://your_qdrant_url
QDRANT_API_KEY=your_qdrant_api_key

# ──────────────────────────────────────────
# Groq API
# ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
